# WhatsApp Business Cloud API credentials
# Get these from https://developers.facebook.com → Your App → WhatsApp → API Setup

# Your WhatsApp Business Phone Number ID
PHONE_NUMBER_ID=your_phone_number_id

# Permanent access token from Meta Developer Portal
WHATSAPP_ACCESS_TOKEN=your_access_token

# Any random string you choose — must match the value you enter in Meta's webhook config
VERIFY_TOKEN=your_verify_token

# Server port (optional, defaults to 3000)
PORT=3000
